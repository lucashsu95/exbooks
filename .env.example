# Database
DB_PASSWORD=
DB_NAME=exbook
DB_USER=root
DB_HOST=db
DB_PORT=3306

# Django
SECRET_KEY=change-me-to-a-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Gunicorn
GUNICORN_WORKERS=3

# Docker Compose
PORT=80

# ============================================
# Google OAuth 2.0 設定
# ============================================
# 請在 Google Cloud Console 建立OAuth 2.0 憑證後填入
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
#
# 本地開發授權設定：
# - Authorized JavaScript origins: http://localhost:8000
# - Authorized redirect URIs: http://localhost:8000/accounts/google/login/callback/
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email 設定
# 生產環境建議使用 SMTP (如 Gmail, SendGrid, Brevo)
# 本地開發可使用 console backend（驗證連結會顯示在 terminal）
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Exbooks <your-email@gmail.com>

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=